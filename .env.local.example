# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.

# Supabase — get from Project Settings → API → Publishable and secret API keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...            # safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...                     # SERVER ONLY — never expose

# Field-level encryption master key (32 bytes hex)
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=

# Resend — get from https://resend.com/api-keys
RESEND_API_KEY=re_...
# Optional: sender identity. Defaults to Resend's onboarding sender until
# admin@carbuyinghub.com domain DNS verifies in Resend.
RESEND_FROM_EMAIL=CarBuyingHub <onboarding@resend.dev>
# Where internal new-application alerts get delivered
ADMIN_NOTIFY_EMAIL=jmcneil221@gmail.com
